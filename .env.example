# ─── AI Voice Data Marketplace — Environment Template ─────────────────────────
# Copy this file to .env.docker and fill in your real values.
# NEVER commit .env.docker to git — it contains secrets.

# ─── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-generate-with-python-secrets
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourapp.up.railway.app

# ─── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
POSTGRES_DB=voicemarket
POSTGRES_USER=voicemarket
POSTGRES_PASSWORD=your-db-password

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Email (Gmail SMTP) ────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=VoiceMarket <your-email@gmail.com>

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── Google Drive ─────────────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_FOLDER_ID=

# ─── Storage ──────────────────────────────────────────────────────────────────
MEDIA_ROOT=/app/media
STATIC_ROOT=/app/staticfiles

# ─── Site ─────────────────────────────────────────────────────────────────────
SITE_NAME=AI Voice Data Marketplace
SITE_URL=https://yourapp.up.railway.app
CURRENCY=INR
DEFAULT_PER_MINUTE_RATE=2.50

# ─── WebRTC STUN/TURN ─────────────────────────────────────────────────────────
TURN_SERVER_URL=stun:stun.l.google.com:19302
TURN_SERVER_USERNAME=
TURN_SERVER_CREDENTIAL=

# ─── WhatsApp/Twilio (optional) ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# ─── Security ─────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://yourapp.up.railway.app
